# ============================================================================
#  Email delivery for the Contact & Join forms (via Resend)
# ============================================================================
#  Copy this file to ".env.local" and fill in RESEND_API_KEY.
#  ".env.local" is git-ignored — never commit your real key.
#  On Vercel, add these in: Project → Settings → Environment Variables.
# ============================================================================

# REQUIRED — your Resend API key. Get one free at https://resend.com
# (sign up using sanatanshivshakti.howrah@gmail.com so it can deliver to that inbox
#  without verifying a domain).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — where form submissions are delivered.
# Defaults to the email set in content/contact.ts.
# CONTACT_TO_EMAIL=sanatanshivshakti.howrah@gmail.com

# OPTIONAL — the "From" address shown on the email.
# Keep the onboarding sender until you verify your own domain in Resend.
# CONTACT_FROM_EMAIL="Sanatan Shiv Shakti <onboarding@resend.dev>"
